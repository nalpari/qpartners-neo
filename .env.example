# Prisma CLI (migrations, generate)
DATABASE_URL="mysql://user:password@host:3306/dbname"

# App runtime (adapter connection)
DB_HOST="host"
DB_PORT="3306"
DB_USER="user"
DB_PASSWORD="password"
DB_NAME="dbname"

# QSP Base URL (optional, 기본값: https://jp-dev.qsalesplatform.com)
# QSP_BASE_URL="https://jp-dev.qsalesplatform.com"

# JWT
JWT_SECRET="your-secret-key"

# OTP HMAC 키 (JWT_SECRET과 분리 권장, 프로덕션 필수)
# 개발환경에서는 미설정 시 JWT_SECRET을 폴백으로 사용
OTP_SECRET="your-otp-secret-key"

# SMTP 인증 (host/port/from 기본값은 src/lib/config.ts 참조)
SMTP_USER=""
SMTP_PASS=""
# SMTP_HOST="smtp.alpha-prm.jp"  (optional, 기본값 있음)
# SMTP_PORT="587"                 (optional, 기본값 있음)
# SMTP_FROM="q-partners@hqj.co.jp" (optional, 기본값 있음)

# 개발환경 Ethereal 테스트 SMTP (SMTP_USER/PASS 없이 메일 테스트, 서버 로그에서 Preview URL 확인)
# SMTP_USE_ETHEREAL="true"

# Site URL (optional, 기본값: https://dev.q-partners.q-cells.jp)
# SITE_URL="https://dev.q-partners.q-cells.jp"

# 파일 업로드 저장 경로 (optional, 기본값: {project}/storage/uploads)
# Docker: /data/uploads, 로컬 개발: 미설정 시 프로젝트 루트 fallback
# UPLOAD_DIR="/data/uploads"

# 자동로그인: Q.Order/Q.Musubi 자동로그인 엔드포인트는 QSP 도메인에 호스팅됨
# (별도 환경변수 불필요 — QSP_BASE_URL 공유)
# AES-256-CBC 키 파생에 사용되는 시크릿 (실제 키 = SHA-256(YYYYMMDD_KST + AUTO_LOGIN_AES_KEY))
# REQUIRED — 빈 값이면 자동로그인 encrypt/decrypt 호출 시 ConfigError(500) 발생
# QSP 측과 합의된 고정 시크릿 사용 필수 (길이·포맷은 QSP 규격을 따름, 임의 변경 금지)
AUTO_LOGIN_AES_KEY=""

# 자동로그인 decrypt 엔드포인트 호출자(QSP) 검증용 공유 비밀
# 설정 시 QSP는 요청에 X-QSP-Auth 헤더로 동일 값 전달 필수 (timingSafeEqual 비교)
# 기본값은 "모든 환경(dev/stg/prd)에서 필수" — 미설정 시 decrypt 엔드포인트 호출 시 ConfigError(500)
# 로컬 dev 에서만 AUTO_LOGIN_REQUIRE_CALLER_SECRET=false 로 강제 비활성화 가능
# AUTO_LOGIN_DECRYPT_SECRET=""

# 자동로그인 호출자 시크릿 필수 여부 (기본: true).
# "false" 또는 "0" 으로 설정 시 AUTO_LOGIN_DECRYPT_SECRET 미설정을 허용 (로컬 dev 전용).
# staging/production 에서는 절대 false로 두지 말 것 — cipher↔userId Oracle 노출 위험.
# AUTO_LOGIN_REQUIRE_CALLER_SECRET="true"

# QSP 응답 url 허용 호스트 화이트리스트 (콤마 구분).
# 미설정 시 기본값: "hanasys.jp,hanasys.co.jp,q-cells.jp"
# 환경별 QSP 반환 호스트가 다를 경우 (예: staging에서 qsalesplatform.com 반환) 이 값으로 덮어쓰기.
# 정확 일치 또는 `.{allowed}` 서브도메인 허용.
# AUTO_LOGIN_ALLOWED_REDIRECT_HOSTS="hanasys.jp,hanasys.co.jp,q-cells.jp"
