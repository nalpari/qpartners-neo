# Prisma CLI (migrations, generate)
DATABASE_URL="mysql://user:password@host:3306/dbname"

# App runtime (adapter connection)
DB_HOST="host"
DB_PORT="3306"
DB_USER="user"
DB_PASSWORD="password"
DB_NAME="dbname"

# QSP Base URL (optional, 기본값: https://jp-dev.qsalesplatform.com)
# QSP_BASE_URL="https://jp-dev.qsalesplatform.com"

# JWT
JWT_SECRET="your-secret-key"

# OTP HMAC 키 (JWT_SECRET과 분리 권장, 프로덕션 필수)
# 개발환경에서는 미설정 시 JWT_SECRET을 폴백으로 사용
OTP_SECRET="your-otp-secret-key"

# SMTP 인증 (host/port/from 기본값은 src/lib/config.ts 참조)
SMTP_USER=""
SMTP_PASS=""
# SMTP_HOST="smtp.alpha-prm.jp"  (optional, 기본값 있음)
# SMTP_PORT="587"                 (optional, 기본값 있음)
# SMTP_FROM="q-partners@hqj.co.jp" (optional, 기본값 있음)

# 개발환경 Ethereal 테스트 SMTP (SMTP_USER/PASS 없이 메일 테스트, 서버 로그에서 Preview URL 확인)
# SMTP_USE_ETHEREAL="true"

# Site URL (optional, 기본값: https://dev.q-partners.q-cells.jp)
# SITE_URL="https://dev.q-partners.q-cells.jp"

# 자동로그인 AES-128 키 (inbound/outbound 공통, 외부 4개 시스템 QSP/Q.Order/Q.Musubi/Design 단일 공통 키)
# 사양: AES-128-CBC, IV=`YYYYMMDD(KST)+_autoL!!` (16 byte 결정적), 평문=userId, 입력=Base64(ciphertext).
# 값: 외부 4개 시스템과 합의된 16 byte UTF-8 raw key. 길이 불일치 시 ConfigError → 첫 요청 단계에서 차단.
# 2026-05-21: inbound/outbound 키 분리(`AUTO_LOGIN_INBOUND_AES_KEY` / `AUTO_LOGIN_OUTBOUND_AES_KEY`) 번복 —
# 외부 4개 시스템이 이미 단일 공통 키 운영 사양이라 통일.
AUTO_LOGIN_AES_KEY=""

# 자동로그인 대상 URL (3사) — 환경별 주입 필수, 누락 시 부팅 실패.
#   .env.development → dev/통테 URL (개발 서버)
#   운영 Jenkins credential → 운영 URL (host 화이트리스트 검증: www.hanasys.jp / q-order.q-cells.jp / q-musubi.q-cells.jp)
# dev 환경에서 HTTP 사용은 ALLOW_INSECURE_AUTOLOGIN_URL=true opt-in 필요.
# HANASYS_AUTOLOGIN_URL="https://dev.hanasys.jp/login"
# Q_ORDER_AUTOLOGIN_URL="https://q-order-dev.q-cells.jp/eos/login/autoLogin"
# Q_MUSUBI_AUTOLOGIN_URL="https://q-musubi-dev.q-cells.jp/qm/login/autoLogin"

# 파일 업로드 저장 경로 (optional, 기본값: {project}/storage/uploads)
# Docker: /data/uploads, 로컬 개발: 미설정 시 프로젝트 루트 fallback
# UPLOAD_DIR="/data/uploads"

# Google Analytics 4 측정 ID (optional) — 설정 시 layout.tsx 가 gtag.js 자동 삽입.
# 환경별 분리:
#   .env.local       → 로컬 개발자 확인용
#   .env.development → 개발 서버, 고객사 확인용
#   .env.production  → 운영(인프라 담당자가 Jenkins Credentials 에 주입)
# 미설정 시 GA 비활성화 — dev/prod 추적 분리에 활용.
# 형식: G- 로 시작하는 대문자/숫자 (예: G-XXXXXXXXXX). 형식 불일치 시 layout 가 무시.
# NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"
